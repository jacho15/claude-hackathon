# --- Fetch.AI -----------------------------------------------------------------
# Optional: only needed when registering with Agentverse Mailbox.
AGENTVERSE_API_KEY=

# Floor aggregator agent address. Patient agents send VitalsUpdate messages
# here. This value is printed by floor_aggregator.py on first boot — copy it
# into this file (or export it) so the patient agents pick it up.
FLOOR_AGENT_ADDRESS=

# --- Supabase (Person 2 fills these in) --------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Claude API (Person 2 fills this in) -------------------------------------
ANTHROPIC_API_KEY=

# --- Agent runtime knobs -----------------------------------------------------
# Polling cadence for patient agents (seconds). Default: 10.0
PATIENT_POLL_SECONDS=10.0
# Set to "1" to enable verbose vitals logging in agents.
VITALWATCH_DEBUG=0
# Bureau HTTP port (default 8200; avoid 5173 / 8000).
BUREAU_PORT=8200

# --- Phase 2: Bed / Discharge / Facilities -----------------------------------
# HTTP ports for the new agents' staff endpoints.
STAFF_HTTP_PORT=8101
BED_HTTP_PORT=8102
DISCHARGE_HTTP_PORT=8103

# Compressed-time pacing knobs (seconds). Real-life would be ~30 minutes
# each; demo defaults fit a stage beat (~25-35 s end-to-end).
BED_CLEANING_SECONDS=12
BED_TRANSPORT_SECONDS=8
BED_DISCHARGE_PAPERWORK_SECONDS=4

# Default secondary language for Claude-generated discharge summaries.
# en, es, fr, zh, vi (Mandarin / Vietnamese fall back to the English
# template if Claude is disabled).
DEFAULT_DISCHARGE_LANGUAGE=es

# Cosmetic crew label shown in the cleaning_jobs row.
FACILITIES_CREW_LABEL=Crew Alpha

# --- Demo overrides (per-room, optional) -------------------------------------
# Override the scenario for a specific room (mock_vitals presets):
#   baseline | watch | sepsis | bradycardia | hypoxia
# VITALWATCH_SCENARIO_301=sepsis
# VITALWATCH_SCENARIO_303=hypoxia
#
# Put a room on supplemental oxygen (adds 2 to the NEWS2 score):
# VITALWATCH_OXYGEN_305=1
#
# Set the patient's consciousness level (ACVPU). Anything other than
# "A" scores 3 in NEWS2 and trips the single-parameter critical rule:
# VITALWATCH_ACVPU_301=V
#
# Switch a room to NEWS2 SpO2 Scale 2 (target 88-92%, COPD patients):
# VITALWATCH_SPO2SCALE_302=2
